---
import DocsSidebar from "~/components/docs-sidebar.astro"
import type { SidebarData } from "~/lib/docs"

type Props = {
  sidebar: SidebarData
  pathname: string
}

const { sidebar, pathname } = Astro.props
---

<div class="container-wrapper flex flex-1 flex-col px-2">
  <div
    class="min-h-min w-full flex-1 items-start px-0 lg:grid lg:grid-cols-[var(--sidebar-width)_minmax(0,1fr)] lg:[--top-spacing:calc(var(--spacing)*4)] 3xl:fixed:container 3xl:fixed:px-3"
    style="--sidebar-width: 18rem; --top-spacing: 0;"
  >
    <DocsSidebar
      topLevel={sidebar.topLevel}
      components={sidebar.components}
      pathname={pathname}
    />

    <section class="h-full w-full min-w-0">
      <slot />
    </section>
  </div>
</div>
