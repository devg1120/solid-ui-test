---
import CommandMenu from "~/components/command-menu"
import GitHubLink from "~/components/github-link.astro"
import { Icons } from "~/components/icons"
import MobileNav from "~/components/mobile-nav"
import ModeToggle from "~/components/mode-toggle"
import { getSidebarData } from "~/lib/docs"
import { siteConfig } from "~/lib/site"
import { Separator } from "~/registry/ui/separator"

const sidebar = await getSidebarData()
---

<header class="sticky top-0 z-50 w-full bg-background">
  <div class="container-wrapper px-6">
    <div class="container flex h-(--header-height) items-center justify-between gap-4">
      <div class="flex min-w-0 items-center gap-5">
        <MobileNav
          client:load
          menuItems={siteConfig.navItems}
          topLevel={sidebar.topLevel}
          components={sidebar.components}
          class="flex lg:hidden"
        />
        <a
          href="/"
          class="hidden items-center gap-2 text-sm font-semibold tracking-tight lg:inline-flex"
        >
          <Icons.logo class="size-5" />
          <span class="sr-only">{siteConfig.name}</span>
        </a>
        <nav class="hidden items-center gap-1 lg:flex">
          {
            siteConfig.navItems.map((item) => (
              <a
                href={item.href}
                class="inline-flex h-8 items-center rounded-md px-2.5 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>

      <div class="ml-auto flex items-center gap-2 md:flex-1 md:justify-end">
        <div class="hidden w-full flex-1 md:flex md:w-auto md:flex-none">
          <CommandMenu client:load navItems={siteConfig.navItems} components={sidebar.components} />
        </div>
        <Separator
          orientation="vertical"
          class="ml-2 hidden h-4 data-[orientation=vertical]:self-center lg:block"
        />
        <GitHubLink />
        <Separator orientation="vertical" class="h-4 data-[orientation=vertical]:self-center" />
        <ModeToggle client:load />
      </div>
    </div>
  </div>
</header>
