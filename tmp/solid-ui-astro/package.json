    "check": "pnpm lint && pnpm format:check",
    "check:write": "pnpm lint:fix && pnpm format",
    "registry:build": "tsx ./src/scripts/build-registry.ts",
    "icons:build": "tsx ./src/scripts/build-icons.ts",
    "format:icons": "prettier --write \"src/registry/icons/**/*.ts\"",
    "ralph": "bash ./plans/ralph.sh",
    "ralph:once": "bash ./plans/ralph.sh 1"
  },
